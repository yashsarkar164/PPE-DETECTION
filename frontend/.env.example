# Base URL of the FastAPI backend. Leave empty to use the Next.js rewrite
# proxy configured in next.config.mjs (recommended for local dev).
# Set to the real backend origin (e.g. https://api.yoursite.com) in production.
NEXT_PUBLIC_API_URL=

# Used server-side only by the Next.js rewrite proxy in next.config.mjs
BACKEND_URL=http://localhost:8000
