# ============================================================================
# Backend environment configuration
# Copy to .env and fill in real values. Never commit .env to source control.
# ============================================================================

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ppe_user:ppe_password@localhost:5432/ppe_detection

# --- JWT Auth ----------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- YOLO Model ---------------------------------------------------------------
MODEL_PATH=models/iocl_ppe.pt
MODEL_CONFIDENCE_THRESHOLD=0.5
MODEL_IOU_THRESHOLD=0.45
DEVICE=cpu
# DEVICE=cuda:0   # uncomment if a GPU is available

# --- Storage -------------------------------------------------------------------
# 'local' now; swap to 's3' later without changing application code paths,
# see services/storage_service.py
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
LOCAL_RESULTS_DIR=results
MAX_UPLOAD_SIZE_MB=500

# Placeholders for future S3 migration (unused while STORAGE_PROVIDER=local)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# --- CORS ----------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000

# --- App ---------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
